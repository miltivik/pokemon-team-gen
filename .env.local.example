# ==========================================
# CONFIGURACIÓN DE MONETIZACIÓN
# ==========================================

# Google AdSense
# Obtén tu ID en: https://adsense.google.com
# Formato: ca-pub-XXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=pub-7981415143867065

# Ezoic
# Obtén tu ID en: https://www.ezoic.com/
# Tu ID de publisher Ezoic
# NEXT_PUBLIC_EZOIC_ID=

# Ko-Fi
# Tu nombre de usuario de Ko-Fi (sin @)
NEXT_PUBLIC_KOFI_ID=miltivik

# ==========================================
# NOTAS:
# ==========================================
# - Copia este archivo a .env.local y completa los valores
# - Para AdSense: necesitas tener una cuenta approved
# - Para Ezoic: necesitas aplicar y ser aceptado
# - Para Ko-Fi: solo necesitas tu nombre de usuario
#
# RPM (Revenue Per Mille) objetivo: $4
# Combina ambas redes para maximizar ingresos
